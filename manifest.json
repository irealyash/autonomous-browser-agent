{
  "manifest_version": 3,
  "name": "Speedy AI Agent",
  "version": "1.0.0",
  "description": "AI-powered browser automation agent",
  "permissions": [
    "storage",
    "history",
    "tabCapture"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "content/background.js"
  },
  "action": {
    "default_title": "Speedy AI Agent - Hold P to activate"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/ui.js", "content/main.js", "content/actions.js"],
      "css": ["assets/style.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "settings.html"
}
